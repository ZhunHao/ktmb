{
  "name": "@zhun_hao/ktmb",
  "version": "0.3.0",
  "description": "Read-only TypeScript library, REST API, and MCP server for KTMB rail data (GTFS + live booking site)",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.19"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "ktmb-mcp": "./dist/bin/ktmb-mcp.js",
    "ktmb-api": "./dist/bin/ktmb-api.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsup && tsc -p tsconfig.build.json",
    "lint": "tsgo --noEmit",
    "inspect:gtfs": "tsx scripts/inspect-gtfs.ts",
    "snapshot": "tsx scripts/build-snapshot.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cheerio": "^1.2.0",
    "chrono-node": "^2.9.0",
    "csv-parse": "^6.2.1",
    "fflate": "^0.8.2",
    "fuse.js": "^7.3.0",
    "gtfs-realtime-bindings": "^1.1.1",
    "hono": "4.12.16",
    "lru-cache": "^11.3.6",
    "p-queue": "^9.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@hono/node-server": "^2.0.1",
    "@types/node": "^22.19.0",
    "@typescript/native-preview": "7.0.0-dev.20260430.1",
    "@vitest/coverage-v8": "^4.1.5",
    "msw": "^2.14.3",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
