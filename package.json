{
  "name": "ktmb",
  "version": "0.1.0",
  "description": "Read-only TypeScript library, REST API, and MCP server for KTMB rail data (GTFS + live booking site)",
  "license": "MIT",
  "type": "module",
  "engines": { "node": ">=20" },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "ktmb-mcp": "./dist/bin/ktmb-mcp.js",
    "ktmb-api": "./dist/bin/ktmb-api.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsup && tsc -p tsconfig.build.json",
    "lint": "tsgo --noEmit",
    "inspect:gtfs": "tsx scripts/inspect-gtfs.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chrono-node": "^2.9.0",
    "csv-parse": "^5.5.6",
    "fflate": "^0.8.2",
    "fuse.js": "^7.3.0",
    "gtfs-realtime-bindings": "^1.1.1",
    "hono": "^4.12.15",
    "lru-cache": "^11.0.2",
    "p-queue": "^9.1.2",
    "undici": "^8.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@hono/node-server": "^1.13.7",
    "@types/node": "^22.10.0",
    "@typescript/native-preview": "^7.0.0-dev.20260426.1",
    "msw": "^2.13.6",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  }
}
